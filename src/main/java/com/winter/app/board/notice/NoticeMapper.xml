<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.winter.app.board.notice.NoticeMapper">
  	<!-- File -->
  	<insert id="createFile" parameterType="NoticeFileDTO">
  		INSERT INTO TB_NOTICEFILE VALUES (
  			NOTICE_SEQ.NEXTVAL,
  			#{fileName},
  			#{oriName},
  			#{noticeNum}
  		)
  	</insert>
  	<!-- File 끝 -->
  	<sql id="search">
  		WHERE
  		<choose>
  			<when test="kind=='v2'">NOTICE_CONTENTS</when>
  			<when test="kind=='v3'">NOTICE_WRITER</when>
  			<otherwise>NOTICE_TITLE</otherwise>
  		</choose>
  		<!-- 
  		<if test="kind=='v1'">
  			NOTICE_TITLE
  		</if>
  		<if test="kind=='v2'">
  			NOTICE_CONTENTS
  		</if>
  		<if test="kind=='v3'">
  			NOTICE_WRITER
  		</if>
  		<if test="kind==null">
  			NOTICE_TITLE
  		</if>
  		-->
  		LIKE '%'||#{search}||'%'
  	</sql>
  
  	<select id="getCount" resultType="Long" parameterType="Pager">
  		SELECT COUNT(NOTICE_NUM) FROM TB_NOTICE
  		<include refid="search"></include>
  		
  	</select>
  	
  	<select id="list" resultType="NoticeDTO" parameterType="Pager">
			SELECT * FROM 
			(
				SELECT ROWNUM R, T.* FROM
				(
					SELECT * FROM TB_NOTICE
					<include refid="search"></include>
					ORDER BY NOTICE_NUM DESC
				) T
			)
			WHERE R BETWEEN #{first} AND #{last}
  	</select>
  	
  	<select id="detail" parameterType="NoticeDTO" resultMap="detailResult">
  		SELECT * FROM TB_NOTICE N
  		LEFT JOIN
  		TB_NOTICEFILE F
  		USING(NOTICE_NUM)
  		WHERE NOTICE_NUM = #{noticeNum}
  	</select>
  	
  	<resultMap type="NoticeDTO" id="detailResult">
  		<!-- Primary Key -->
  		<id column="NOTICE_NUM" property="noticeNum"/>
  		<!-- 그외 나머지 -->
  		<result column="NOTICE_TITLE" property="noticeTitle"/>
  		<result column="NOTICE_WRITER" property="noticeWriter"/>
  		<result column="NOTICE_CONTENTS" property="noticeContents"/>
  		<result column="CREATE_AT" property="createAt"/>
  		<result column="VIEW_COUNT" property="viewCount"/>
  		<!-- 1:N -->
  		<collection property="list" javaType="java.util.List" ofType="NoticeFileDTO">
  			<id column="FILE_NUM" property="fileNum"/>
  			<result column="FILE_NAME" property="fileName"/>
  			<result column="ORI_NAME" property="oriName"/>
  		</collection>
  	</resultMap>
  	
  	<insert id="create" parameterType="NoticeDTO">
  		<selectKey order="BEFORE" resultType="Long" keyProperty="noticeNum">
  			SELECT NOTICE_SEQ.NEXTVAL FROM DUAL
  		</selectKey>
  		INSERT INTO TB_NOTICE VALUES (
  			#{noticeNum},
  			#{noticeTitle},
  			#{noticeContents},
  			#{noticeWriter},
  			sysdate,
  			0
  		)
  	</insert>
  	
  	<delete id="delete" parameterType="NoticeDTO">
  		DELETE FROM TB_NOTICE WHERE NOTICE_NUM=#{noticeNum}
  	</delete>
  	
  	<update id="update" parameterType="NoticeDTO">
  		UPDATE TB_NOTICE SET
  			NOTICE_TITLE=#{noticeTitle},
  			NOTICE_CONTENTS=#{noticeContents},
  			NOTICE_WRITER=#{noticeWriter},
  			CREATED_AT=sysdate,
  			VIEW_COUNT=0
  		WHERE NOTICE_NUM=#{noticeNum}
  	</update>
  	
  </mapper>